# Configuration d'Environnement - Frontend
# Copie ce fichier en .env.local et ajuste les valeurs si nécessaire

# URL du Backend API
VITE_API_URL=http://localhost:8080/api

# Port du Frontend (normalement configuré dans vite.config.ts)
VITE_PORT=3000

# Timeout pour les requêtes API (en millisecondes)
VITE_API_TIMEOUT=10000

# Environment
VITE_ENV=development

